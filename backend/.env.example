# Copy to .env and edit
# Use Postgres:
DATABASE_URL=postgresql+psycopg://postgres:orbit@localhost:5432/orbit
# Or SQLite for zero-setup dev:
# DATABASE_URL=sqlite:///./orbit.db

JWT_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:5173

# Orbit AI (Ask Orbit, AI caption generator). Without this, AI endpoints return 503.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
