# Copy to .env and edit
# Use Postgres:
DATABASE_URL=postgresql+psycopg://postgres:orbit@localhost:5432/orbit
# Or SQLite for zero-setup dev:
# DATABASE_URL=sqlite:///./orbit.db

JWT_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:5173

# Orbit AI (Ask Orbit, AI caption generator). Without this, AI endpoints return 503.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# LinkedIn personal-profile OAuth (Sign In with LinkedIn + Share on LinkedIn products).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/oauth/linkedin/callback
LINKEDIN_SCOPES=openid profile email w_member_social
FRONTEND_URL=http://localhost:5173

# Meta (Facebook + Instagram) OAuth. One app, both platforms.
# Add Facebook Login for Business + Instagram Graph API products on developers.facebook.com.
# For real publishing you must complete Meta App Review for the requested scopes.
META_CLIENT_ID=
META_CLIENT_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/oauth/meta/callback
META_GRAPH_VERSION=v19.0
META_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts,instagram_basic,instagram_content_publish

SCHEDULER_ENABLED=1
SCHEDULER_INTERVAL_SECONDS=30
